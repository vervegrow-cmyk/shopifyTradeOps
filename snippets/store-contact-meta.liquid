{%- liquid
  assign support_email = 'support@dekuch.com'
  assign support_whatsapp = '+1 775 299 9669'
  assign support_whatsapp_tel = '+17752999669'
  assign support_whatsapp_url = 'https://wa.me/17752999669'
  assign company_name = 'SURPLUSLANE INC.'
  assign storefront_name = 'Dekuch'
  assign business_address = '402 Foulk Rd, Apt 4C0, Wilmington, DE 19803, USA'
  assign return_address = '9020 Murphy Rd, Woodridge, IL 60517, USA'
  assign response_time = 'Usually within 24 business hours'

  case field
    when 'support_email'
      echo support_email
    when 'support_email_href'
      if support_email != blank
        echo 'mailto:' | append: support_email
      endif
    when 'support_whatsapp'
      echo support_whatsapp
    when 'support_whatsapp_tel'
      if support_whatsapp_tel != blank
        echo 'tel:' | append: support_whatsapp_tel
      endif
    when 'support_whatsapp_url'
      echo support_whatsapp_url
    when 'company_name'
      echo company_name
    when 'storefront_name'
      echo storefront_name
    when 'business_address'
      echo business_address
    when 'return_address'
      echo return_address
    when 'response_time'
      echo response_time
  endcase
-%}
