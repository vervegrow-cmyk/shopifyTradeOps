{%- liquid
  assign support_email = settings.store_support_email | default: shop.email
  assign support_whatsapp = settings.store_support_phone
  assign support_whatsapp_tel = settings.store_support_whatsapp_tel | default: settings.store_support_phone
  assign support_whatsapp_url = settings.store_support_whatsapp_url
  assign company_name = settings.store_company_name | default: shop.name
  assign storefront_name = settings.store_storefront_name | default: shop.name
  assign business_address = settings.store_business_address
  assign return_address = settings.store_return_address | default: business_address
  assign response_time = settings.store_response_time | default: 'Usually within 1 business day'

  case field
    when 'support_email'
      echo support_email
    when 'support_email_href'
      if support_email != blank
        echo 'mailto:' | append: support_email
      endif
    when 'support_whatsapp'
      echo support_whatsapp
    when 'support_whatsapp_tel'
      if support_whatsapp_tel != blank
        echo 'tel:' | append: support_whatsapp_tel
      endif
    when 'support_whatsapp_url'
      echo support_whatsapp_url
    when 'company_name'
      echo company_name
    when 'storefront_name'
      echo storefront_name
    when 'business_address'
      echo business_address
    when 'return_address'
      echo return_address
    when 'response_time'
      echo response_time
  endcase
-%}
