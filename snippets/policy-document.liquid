{%- liquid
  assign handle = policy_handle | default: request.path | split: '/' | last
  assign policy_type = type | default: 'body'
  assign resolved_policy = blank

  capture support_email
    render 'store-contact-meta', field: 'support_email'
  endcapture
  capture support_email_href
    render 'store-contact-meta', field: 'support_email_href'
  endcapture
  capture support_whatsapp
    render 'store-contact-meta', field: 'support_whatsapp'
  endcapture
  capture support_whatsapp_tel
    render 'store-contact-meta', field: 'support_whatsapp_tel'
  endcapture
  capture support_whatsapp_url
    render 'store-contact-meta', field: 'support_whatsapp_url'
  endcapture
  capture company_name
    render 'store-contact-meta', field: 'company_name'
  endcapture
  capture storefront_name
    render 'store-contact-meta', field: 'storefront_name'
  endcapture
  capture business_address
    render 'store-contact-meta', field: 'business_address'
  endcapture
  capture return_address
    render 'store-contact-meta', field: 'return_address'
  endcapture
  capture response_time
    render 'store-contact-meta', field: 'response_time'
  endcapture
  capture privacy_policy_url
    render 'store-policy-url', policy: 'privacy-policy', fallback: '/policies/privacy-policy'
  endcapture
  capture refund_policy_url
    render 'store-policy-url', policy: 'refund-policy', fallback: '/policies/refund-policy'
  endcapture
  capture shipping_policy_url
    render 'store-policy-url', policy: 'shipping-policy', fallback: '/policies/shipping-policy'
  endcapture
  capture terms_policy_url
    render 'store-policy-url', policy: 'terms-of-service', fallback: '/policies/terms-of-service'
  endcapture

  case handle
    when 'privacy-policy'
      assign resolved_policy = shop.privacy_policy
    when 'refund-policy'
      assign resolved_policy = shop.refund_policy
    when 'shipping-policy'
      assign resolved_policy = shop.shipping_policy
    when 'terms-of-service'
      assign resolved_policy = shop.terms_of_service
  endcase
-%}

{%- if policy_type == 'updated_at' -%}
  {%- if resolved_policy != blank and resolved_policy.updated_at != blank -%}
    {{ resolved_policy.updated_at | date: '%B %d, %Y' }}
  {%- endif -%}
{%- elsif policy_type == 'body' -%}
  {%- if handle == 'contact-information' -%}
    <div class="policy-doc">
      <p>This page is the official contact center for {{ storefront_name | strip }}, operated by <strong>{{ company_name | strip }}</strong>. Use the sections below to contact the right team for order support, return requests, privacy inquiries, shipping questions, or formal business notices.</p>
      <div class="policy-contact-summary">
        <div class="policy-contact-summary__item">
          <strong>Support email</strong>
          <span><a href="{{ support_email_href | strip }}">{{ support_email | strip }}</a></span>
        </div>
        {%- if support_whatsapp != blank -%}
          <div class="policy-contact-summary__item">
            <strong>WhatsApp</strong>
            <span>
              <a href="{% if support_whatsapp_url != blank %}{{ support_whatsapp_url | strip }}{% else %}{{ support_whatsapp_tel | strip }}{% endif %}">
                {{ support_whatsapp | strip }}
              </a>
            </span>
          </div>
        {%- endif -%}
        <div class="policy-contact-summary__item">
          <strong>Response time</strong>
          <span>{{ response_time | strip }}</span>
        </div>
      </div>
      <div class="policy-contact-hero-actions">
        <a class="policy-contact-action policy-contact-action--primary" href="{{ support_email_href | strip }}">Email support</a>
        {%- if support_whatsapp_url != blank -%}
          <a class="policy-contact-action policy-contact-action--secondary" href="{{ support_whatsapp_url | strip }}">Message on WhatsApp</a>
        {%- endif -%}
      </div>
      <div class="policy-contact-grid">
        <article class="policy-contact-card">
          <p class="policy-contact-card__eyebrow">Customer support</p>
          <h2>Email support</h2>
          <p>Use email for order updates, damaged items, refund requests, delivery issues, product questions, and general after-sales support.</p>
          <p><strong>Email:</strong> <a href="{{ support_email_href | strip }}">{{ support_email | strip }}</a></p>
          <p><strong>Response time:</strong> {{ response_time | strip }}</p>
        </article>
        {%- if support_whatsapp != blank -%}
          <article class="policy-contact-card">
            <p class="policy-contact-card__eyebrow">Fast contact</p>
            <h2>WhatsApp support</h2>
            <p>Use WhatsApp for simple pre-sale questions, shipment follow-up, and quick order assistance.</p>
            <p><strong>WhatsApp:</strong> <a href="{{ support_whatsapp_tel | strip }}">{{ support_whatsapp | strip }}</a></p>
          </article>
        {%- endif -%}
      </div>
      <h2>Official business details</h2>
      <div class="policy-contact-details">
        <div>
          <strong>Storefront name</strong>
          <p>{{ storefront_name | strip }}</p>
        </div>
        <div>
          <strong>Legal business</strong>
          <p>{{ company_name | strip }}</p>
        </div>
        {%- if business_address != blank -%}
          <div>
            <strong>Business address</strong>
            <p>{{ business_address | strip }}</p>
          </div>
        {%- endif -%}
        {%- if return_address != blank -%}
          <div>
            <strong>Returns address</strong>
            <p>{{ return_address | strip }}</p>
          </div>
        {%- endif -%}
      </div>
      <h2>Related policy pages</h2>
      <div class="policy-contact-links">
        <a href="{{ refund_policy_url | strip }}">Refund Policy</a>
        <a href="{{ shipping_policy_url | strip }}">Shipping Policy</a>
        <a href="{{ privacy_policy_url | strip }}">Privacy Policy</a>
        <a href="{{ terms_policy_url | strip }}">Terms of Service</a>
      </div>
    </div>
  {%- elsif resolved_policy != blank and resolved_policy.body != blank -%}
    {{ resolved_policy.body }}
  {%- endif -%}
{%- endif -%}
